[physics]

common/physics_ticks_per_second=240
2d/physics_engine="Rapier2D"
rapier/joint/damping_ratio=10.0
rapier/solver/preset=2
rapier/solver/num_internal_pgs_iterations=4
rapier/solver/num_internal_stabilization_iterations=4
rapier/solver/num_iterations=64
rapier/solver/contact_damping_ratio=20.0
rapier/solver/contact_natural_frequency=50.0
rapier/solver/length_unit_2d=9.0

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/canvas_textures/default_texture_repeat=1
